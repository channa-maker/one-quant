# ============================================================
# ONE量化 Docker 环境变量模板
# 复制本文件为 .env 并填入实际值
# ============================================================

# ------------------------------------------------------------
# 数据库
# ------------------------------------------------------------
POSTGRES_DB=one_quant
POSTGRES_USER=one_quant
POSTGRES_PASSWORD=one_quant_dev

TIMESCALE_DB=one_quant_ts
TIMESCALE_USER=one_quant
TIMESCALE_PASSWORD=one_quant_dev

DATABASE_URL=postgresql://one_quant:one_quant_dev@postgres:5432/one_quant
TIMESCALE_URL=postgresql://one_quant:one_quant_dev@timescaledb:5432/one_quant_ts

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------
# ClickHouse
# ------------------------------------------------------------
CLICKHOUSE_URL=http://clickhouse:8123

# ------------------------------------------------------------
# MinIO 对象存储
# ------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=one-quant

# ------------------------------------------------------------
# API 服务
# ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# ------------------------------------------------------------
# 数据源
# ------------------------------------------------------------
TUSHARE_TOKEN=
AKSHARE_ENABLED=true

# ------------------------------------------------------------
# 交易所 API（按需填入）
# ------------------------------------------------------------
# 币安
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=true

# Deribit
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=
DERIBIT_TESTNET=true

# IBKR
IBKR_HOST=
IBKR_PORT=
IBKR_CLIENT_ID=

# ------------------------------------------------------------
# AI / LLM
# ------------------------------------------------------------
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ------------------------------------------------------------
# 日志与监控
# ------------------------------------------------------------
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true

# ------------------------------------------------------------
# Grafana
# ------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=admin

# ------------------------------------------------------------
# 通知（按需配置）
# ------------------------------------------------------------
NOTIFIER_WEBHOOK_URL=
NOTIFIER_TELEGRAM_BOT_TOKEN=
NOTIFIER_TELEGRAM_CHAT_ID=
